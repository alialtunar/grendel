Screen {
    layout: vertical;
}

#header {
    height: auto;
    padding: 0 1;
    background: $panel;
    color: $text;
    text-style: bold;
}

#progress {
    height: 1;
    padding: 0 1;
}

#body {
    height: 1fr;
}

#left {
    width: 55%;
}

#detail {
    width: 45%;
    padding: 0 1;
    border-left: solid $primary;
}

#categories {
    height: 1fr;
}

#failures {
    height: 1fr;
}
